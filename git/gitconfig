[user]
    name = asamadiya
    email = asamadiya@users.noreply.github.com

[core]
    pager = delta
    editor = vim
    autocrlf = input

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    syntax-theme = Catppuccin Mocha
    line-numbers = true
    side-by-side = false
    file-style = bold yellow ul
    hunk-header-style = omit

[color]
    ui = auto

[diff]
    colorMoved = default
    algorithm = histogram

[merge]
    conflictstyle = zdiff3
    tool = vimdiff

[push]
    default = current
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[rerere]
    enabled = true

[alias]
    st = status
    ci = commit
    ca = commit -a --amend -C HEAD
    br = branch
    co = checkout
    ds = diff --staged
    sw = switch
    sc = switch -c
    unstage = reset HEAD --
    last = log -1 HEAD --stat
    amend = commit --amend --no-edit
    wip = !git add -A && git commit -m 'wip'
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
    sglog = log --graph --decorate --pretty=oneline --abbrev-commit
    glog = log --graph --decorate --pretty=oneline --abbrev-commit --all --date=local
    ls = ls-files

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process

[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
